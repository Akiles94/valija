{
  "name": "valija",
  "version": "0.1.0",
  "description": "Open source, end-to-end encrypted context vault for developers who use several AI tools. Local MCP server + CLI.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "valija": "dist/program.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "context",
    "vault",
    "encryption",
    "sqlcipher",
    "ai-tools",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osvinueza/valija.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "argon2": "^0.44.0",
    "better-sqlite3-multiple-ciphers": "^12.11.1",
    "commander": "^15.0.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  }
}
